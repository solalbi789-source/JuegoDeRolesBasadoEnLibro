// src/app/components/figma/ImageWithFallback.tsx
import React, { useState, useEffect } from 'react';

interface ImageProps extends React.ImgHTMLAttributes<HTMLImageElement> {
  fallbackSrc?: string;
}

export const ImageWithFallback = ({ 
  src, 
  fallbackSrc = '/images/placeholder.png', // Podés cambiar esto por la ruta de tu imagen por defecto
  alt, 
  className, 
  ...props 
}: ImageProps) => {
  const [imgSrc, setImgSrc] = useState<string | undefined>(src);
  const [loading, setLoading] = useState(true);

  // Si cambia el src (por ejemplo, el personaje cambia de equipamiento o cambias de escena)
  useEffect(() => {
    setImgSrc(src);
    setLoading(true);
  }, [src]);

  return (
    <div className={`relative overflow-hidden ${className || ''}`}>
      {/* Esqueleto de carga animado mientras la imagen se descarga en segundo plano */}
      {loading && (
        <div className="absolute inset-0 bg-muted animate-pulse rounded-md" />
      )}
      
      <img
        {...props}
        src={imgSrc}
        alt={alt || 'Imagen del juego'}
        loading="lazy" // Clave para el rendimiento: solo descarga si está en pantalla
        onLoad={() => setLoading(false)}
        onError={() => {
          setImgSrc(fallbackSrc);
          setLoading(false);
        }}
        className={`transition-opacity duration-300 ease-in-out w-full h-full object-cover ${
          loading ? 'opacity-0' : 'opacity-100'
        }`}
      />
    </div>
  );
};

export default ImageWithFallback;
